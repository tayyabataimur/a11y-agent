{
  "name": "loop11y",
  "version": "0.1.0",
  "description": "Universal MCP and CLI tool for evaluating, fixing, and enforcing accessibility across any website or web app",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./harness-sdk": "./dist/integrations/harness-sdk.js"
  },
  "bin": {
    "loop11y": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "playwright install chromium --with-deps 2>/dev/null || true"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "mcp",
    "model-context-protocol",
    "axe-core",
    "agentic",
    "cli",
    "web-accessibility",
    "assistive-technology",
    "compliance",
    "openapi",
    "api",
    "react",
    "nextjs",
    "vue",
    "svelte",
    "angular"
  ],
  "author": "Tayyaba Taimur",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axe-core": "^4.10.0",
    "playwright": "^1.48.0",
    "ts-morph": "^23.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
